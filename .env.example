# Режим: mock | web3forms | formspree | webhook | whatsapp
VITE_FORM_MODE=mock

# Письма на вашу почту (бесплатно): https://web3forms.com
# Укажите email получателя на сайте → скопируйте Access Key сюда:
# VITE_FORM_MODE=web3forms
# VITE_WEB3FORMS_ACCESS_KEY=
# Ключ Cloudflare Turnstile для captcha: https://dash.cloudflare.com/?to=/:account/turnstile
# VITE_TURNSTILE_SITE_KEY=
# Заглушка URL после заявки (Instagram и т.п.), пока можно оставить #
# VITE_INSTAGRAM_AFTER_STUB_URL=#

# Для Formspree / Getform — вставьте URL формы
# VITE_FORM_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Для Google Sheets / CRM — URL вебхука (POST JSON)
# VITE_WEBHOOK_URL=https://script.google.com/macros/s/.../exec

# WhatsApp: только цифры кода страны и номера, без +
# VITE_WHATSAPP_PHONE=79991234567
